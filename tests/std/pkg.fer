let assert = import('std/assert');

let pkg = import('std/pkg');
let vec = import('std/vec');
let version = import('std/version');

# --- pkg.new() ---

let project = pkg.new(
    name = 'TestPkg',
    desc = 'A test package',
    version = '1.2.3',
    authors = vec.new('Author One', 'Author Two')
);

assert.eq(project.name, 'TestPkg');
assert.eq(project.desc, 'A test package');
assert.eq(project.version, version.parse('1.2.3'));
assert.eq(project.authors[0], 'Author One');
assert.eq(project.authors[1], 'Author Two');
assert.eq(project.dependencies.len(), 0);
assert.eq(project.targets.len(), 0);

# getProjects() contains the created project
let projs = pkg.getProjects();
assert.eq(projs.len(), 1);
assert.eq(projs[0].name, 'TestPkg');

# feral version constraint — must match current interpreter
pkg.new(name = 'FeralOk', version = '0.0.1', feral = '>=0.0.1');
assert.eq(pkg.getProjects().len(), 2);

# feral version constraint — incompatible interpreter raises
pkg.new(name = 'FeralBad', version = '0.0.1', feral = '>=999.0.0') or e {
    assert.eq(e.str(), 'Raised: package requires Feral `>=999.0.0`, but currently running version `' + feral.version + '`');
    return nil;
};

# incompatible feral version does not register the project
assert.eq(pkg.getProjects().len(), 2);

# --- project.requires() ---

let dep = project.requires('CURL', '>=3.0.0', linkAs = 'CURL::libcurl');
assert.eq(project.dependencies.len(), 1);
assert.eq(dep.name, 'CURL');
assert.eq(dep.constraint.str(), '>=3.0.0');
assert.eq(dep.linkAs, 'CURL::libcurl');
assert.eq(dep.isFeral, false);

# default linkAs = name, isFeral = false
let dep2 = project.requires('NativeLib', '>=1.0.0');
assert.eq(dep2.linkAs, 'NativeLib');
assert.eq(dep2.isFeral, false);

# isFeral = true
let dep3 = project.requires('Progress', '>=0.0.1', isFeral = true);
assert.eq(dep3.isFeral, true);
assert.eq(dep3.linkAs, 'Progress');
assert.eq(project.dependencies.len(), 3);

# returned dep references the same object as in project.dependencies
assert.eq(dep.name, project.dependencies[0].name);
assert.eq(dep.constraint.str(), project.dependencies[0].constraint.str());

# invalid constraint raises
project.requires('Bad', '>=') or e { return nil; };

# --- project.addTarget() ---

let target = project.addTarget('Curl', 'Curl.cpp', 'Extra.cpp');
assert.eq(project.targets.len(), 1);
assert.eq(target.name, 'Curl');
assert.eq(target.sources.len(), 2);
assert.eq(target.sources[0], 'Curl.cpp');
assert.eq(target.sources[1], 'Extra.cpp');

# returned target references the same object as in project.targets
assert.eq(target.name, project.targets[0].name);

# multiple targets
project.addTarget('CurlCLI', 'CLI.cpp');
assert.eq(project.targets.len(), 2);
assert.eq(project.targets[1].name, 'CurlCLI');
