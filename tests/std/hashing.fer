let assert = import('std/assert');

let hashing = import('std/hashing');

# NIST FIPS 180-4 test vectors.
assert.eq(hashing.sha256(''), 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855');
assert.eq(hashing.sha256('abc'), 'ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad');

# 56-byte message — forces two 512-bit padding blocks (also a NIST vector).
assert.eq(hashing.sha256('abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq'),
          '248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1');

# Additional well-known vectors.
assert.eq(hashing.sha256('hello'),
          '2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824');
assert.eq(hashing.sha256('The quick brown fox jumps over the lazy dog'),
          'd7a8fbb307d7809469ca9abcb0082e4f8d5651e46d3cdb762d02d0bf37c9e592');
